# Kora RFI - Environment Variables
# Copy this file to .env and fill in your values

# === REQUIRED ===

# OpenRouter API (for all LLM calls)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ReadyPlayerMe Avatar URL (GLB model URL)
READYPLAYERME_AVATAR_URL=https://models.readyplayer.me/your-avatar-id.glb

# ElevenLabs Voice ID (for TTS)
VOICE_ID=your_elevenlabs_voice_id_here

# === OPTIONAL ===

# ElevenLabs API Key (for voice synthesis)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Server Port (local development only)
PORT=8888
