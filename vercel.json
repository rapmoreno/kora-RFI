{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "build": {
    "env": {
      "NODE_VERSION": "20"
    }
  },
  "buildCommand": "npm run build:ts",
  "installCommand": "npm install",
  "functions": {
    "api/index.js": {
      "runtime": "@vercel/node@3.2.0",
      "includeFiles": "dist/**,prompts/**,public/**,index.html,chat-ui.html,styles/**,web-components/**,js/**,scripts/**,agents/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/chat", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/api/index.js" }
  ]
}
